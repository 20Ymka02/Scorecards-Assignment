<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Board Game Scorecard</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <h2>🎲 Monopoly Session</h2>
    <table>
        <thead>
            <tr>
                <th>Player Name</th>
                <th>Round 1</th>
                <th>Round 2</th>
                <th>Round 3</th>
                <th>Round 4</th>
                <th>Cash ($)</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Emily</td>
                <td>+200</td>
                <td>-50</td>
                <td>+150</td>
                <td>+100</td>
                <td>1400</td>
            </tr>
            <tr>
                <td>Sophia</td>
                <td>+100</td>
                <td>+200</td>
                <td>-300</td>
                <td>+50</td>
                <td>1050</td>
            </tr>
            <tr>
                <td>Lily</td>
                <td>+500</td>
                <td>-100</td>
                <td>+200</td>
                <td>-150</td>
                <td>1450</td>
            </tr>
        </tbody>
    </table>
</body>
</html>
